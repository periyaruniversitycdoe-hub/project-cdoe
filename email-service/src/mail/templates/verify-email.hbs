<!DOCTYPE html>
<html lang="en" xmlns:v="urn:schemas-microsoft-com:vml" xmlns:o="urn:schemas-microsoft-com:office:office">
<head>
  <meta charset="UTF-8" />
  <meta name="x-apple-disable-message-reformatting" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <title>Verify Your Email — {{universityName}}</title>
  <!--[if mso]>
  <noscript>
    <xml><o:OfficeDocumentSettings><o:PixelsPerInch>96</o:PixelsPerInch></o:OfficeDocumentSettings></xml>
  </noscript>
  <![endif]-->
  <style>
    * { box-sizing: border-box; }
    body, table, td, a { -webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; }
    table, td { mso-table-lspace: 0; mso-table-rspace: 0; }
    img { -ms-interpolation-mode: bicubic; border: 0; height: auto; line-height: 100%; outline: none; text-decoration: none; }
    body { margin: 0; padding: 0; background-color: #f0fdf4; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; }

    @media only screen and (max-width: 600px) {
      .email-wrapper { width: 100% !important; }
      .email-content { padding: 20px !important; }
      .verify-btn    { display: block !important; text-align: center !important; }
      .hero-title    { font-size: 22px !important; }
    }
  </style>
</head>
<body style="margin:0;padding:0;background-color:#f0fdf4;">

  <!-- Pre-header -->
  <div style="display:none;max-height:0;overflow:hidden;mso-hide:all;">
    Please verify your email address to activate your {{universityName}} ERP account. Link expires in {{expiresInHours}} hours. &#8203;&#8203;&#8203;
  </div>

  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0"
         style="background-color:#f0fdf4;padding:40px 20px;">
    <tr>
      <td align="center">
        <!-- Email Card -->
        <table class="email-wrapper" role="presentation" width="600" cellpadding="0" cellspacing="0" border="0"
               style="max-width:600px;width:100%;background:#ffffff;border-radius:12px;overflow:hidden;
                      box-shadow:0 4px 24px rgba(0,0,0,0.07);">

          <!-- ══ Header ══ -->
          <tr>
            <td style="background:linear-gradient(135deg,#059669 0%,#047857 100%);padding:32px 40px;text-align:center;">
              <div style="font-size:26px;font-weight:800;color:#ffffff;letter-spacing:-0.5px;margin-bottom:4px;">
                🎓 {{universityName}}
              </div>
              <div style="font-size:13px;color:rgba(255,255,255,0.75);letter-spacing:1px;text-transform:uppercase;">
                Enterprise Resource Planning Portal
              </div>
            </td>
          </tr>

          <!-- ══ Hero ══ -->
          <tr>
            <td style="background:linear-gradient(180deg,#f0fdf4 0%,#ffffff 100%);
                       padding:40px 40px 24px;text-align:center;border-bottom:1px solid #e2e8f0;">
              <!-- Envelope icon -->
              <div style="width:72px;height:72px;background:linear-gradient(135deg,#059669,#10b981);
                          border-radius:50%;margin:0 auto 20px;display:flex;align-items:center;
                          justify-content:center;font-size:32px;line-height:72px;text-align:center;">
                ✉️
              </div>
              <h1 class="hero-title"
                  style="margin:0 0 12px;font-size:26px;font-weight:800;color:#1e293b;line-height:1.2;">
                Confirm Your Email Address
              </h1>
              <p style="margin:0;font-size:15px;color:#64748b;line-height:1.6;">
                Hi <strong style="color:#1e293b;">{{fullName}}</strong>, you're almost there!<br />
                Click the button below to verify your email and activate your account.
              </p>
            </td>
          </tr>

          <!-- ══ Body ══ -->
          <tr>
            <td class="email-content" style="padding:36px 40px;">

              <!-- Verify Button -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0"
                     style="text-align:center;margin-bottom:32px;">
                <tr>
                  <td>
                    <a class="verify-btn" href="{{verifyLink}}"
                       style="display:inline-block;background:linear-gradient(135deg,#059669,#047857);
                              color:#ffffff;text-decoration:none;font-size:16px;font-weight:700;
                              padding:16px 48px;border-radius:8px;letter-spacing:0.3px;
                              box-shadow:0 4px 14px rgba(5,150,105,0.4);">
                      ✓ &nbsp;Verify My Email Address
                    </a>
                  </td>
                </tr>
              </table>

              <!-- Expiry Notice -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0"
                     style="background:#fefce8;border:1px solid #fde047;border-radius:8px;
                            margin-bottom:28px;overflow:hidden;">
                <tr>
                  <td style="padding:14px 20px;">
                    <p style="margin:0;font-size:13px;color:#854d0e;line-height:1.6;">
                      ⏰ <strong>This link expires in {{expiresInHours}} hours.</strong>
                      If it expires, you can request a new verification email from the login page.
                    </p>
                  </td>
                </tr>
              </table>

              <!-- Fallback link -->
              <p style="margin:0 0 8px;font-size:14px;color:#374151;line-height:1.6;">
                If the button above doesn't work, copy and paste the following URL into your browser:
              </p>
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0"
                     style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:6px;
                            margin-bottom:28px;overflow:hidden;">
                <tr>
                  <td style="padding:12px 16px;">
                    <p style="margin:0;font-size:12px;color:#2563eb;word-break:break-all;
                               font-family:'Courier New',Courier,monospace;line-height:1.5;">
                      {{verifyLink}}
                    </p>
                  </td>
                </tr>
              </table>

              <!-- Divider -->
              <hr style="border:none;border-top:1px solid #e2e8f0;margin:24px 0;" />

              <!-- What happens next -->
              <p style="margin:0 0 12px;font-size:14px;font-weight:700;color:#1e293b;">
                After verification you can:
              </p>
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td style="padding:5px 0;font-size:14px;color:#374151;line-height:1.5;">
                    ✅ &nbsp;Submit your Ph.D. application
                  </td>
                </tr>
                <tr>
                  <td style="padding:5px 0;font-size:14px;color:#374151;line-height:1.5;">
                    ✅ &nbsp;Upload required documents
                  </td>
                </tr>
                <tr>
                  <td style="padding:5px 0;font-size:14px;color:#374151;line-height:1.5;">
                    ✅ &nbsp;Track your application status
                  </td>
                </tr>
                <tr>
                  <td style="padding:5px 0;font-size:14px;color:#374151;line-height:1.5;">
                    ✅ &nbsp;Download your hall ticket when issued
                  </td>
                </tr>
              </table>

            </td>
          </tr>

          <!-- ══ Security Notice ══ -->
          <tr>
            <td style="background:#fff1f2;border-top:1px solid #fecdd3;
                       border-bottom:1px solid #fecdd3;padding:16px 40px;">
              <p style="margin:0;font-size:13px;color:#9f1239;line-height:1.6;">
                🔒 <strong>Didn't request this?</strong> If you did not create an account on
                {{universityName}} ERP, you can safely ignore this email. Your email address
                will not be associated with any account.
                <br />
                For concerns: <a href="mailto:{{supportEmail}}" style="color:#be123c;">{{supportEmail}}</a>
              </p>
            </td>
          </tr>

          <!-- ══ Footer ══ -->
          <tr>
            <td style="padding:28px 40px;background:#f8fafc;border-top:1px solid #e2e8f0;text-align:center;">
              <p style="margin:0 0 8px;font-size:13px;color:#94a3b8;">
                © {{year}} {{universityName}}. All rights reserved.
              </p>
              <p style="margin:0 0 8px;font-size:12px;color:#94a3b8;">
                Salem — 636 011, Tamil Nadu, India
              </p>
              <p style="margin:0;font-size:12px;color:#cbd5e1;">
                This is an automated message. Please do not reply to this email.<br />
                Support: <a href="mailto:{{supportEmail}}" style="color:#059669;text-decoration:none;">{{supportEmail}}</a>
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
