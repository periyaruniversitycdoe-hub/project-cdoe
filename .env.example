# ═════════════════════════════════════════════════════════════════════════════
# PhD Admission Management System — Environment Configuration Template
# Copy this file to .env and fill in all values before starting Docker.
# NEVER commit .env with real secrets to git.
# ═════════════════════════════════════════════════════════════════════════════

# ── Environment ───────────────────────────────────────────────────────────────
NODE_ENV=production
TAG=latest

# ── Docker Image Tag ──────────────────────────────────────────────────────────
# Used to version images: docker compose build && docker compose push
# TAG=v1.0.0

# ── Database — MySQL ──────────────────────────────────────────────────────────
# DB_HOST must be "mysql" when running inside Docker (container name)
# Use "localhost" only for local development outside Docker
DB_HOST=mysql
DB_PORT=3306
DB_NAME=rsm_db

# Root password (used only during MySQL init to create the app user)
DB_ROOT_PASSWORD=CHANGE_THIS_ROOT_PASSWORD

# Application user (least-privilege: SELECT/INSERT/UPDATE/DELETE only)
DB_USER=rsm_app
DB_PASSWORD=CHANGE_THIS_APP_PASSWORD

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD

# ── JWT Secrets — each portal gets its own secret ────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
STUDENT_JWT_SECRET=CHANGE_THIS_STUDENT_JWT_SECRET_64_CHARS_MIN
ADMIN_JWT_SECRET=CHANGE_THIS_ADMIN_JWT_SECRET_64_CHARS_MIN
SUPERVISOR_JWT_SECRET=CHANGE_THIS_SUPERVISOR_JWT_SECRET_64_CHARS_MIN
CENTER_JWT_SECRET=CHANGE_THIS_CENTER_JWT_SECRET_64_CHARS_MIN

# ── Frontend Public URLs (used by nginx + CORS config) ────────────────────────
STUDENT_FRONTEND_URL=https://student.university.com
ADMIN_FRONTEND_URL=https://admin.university.com
SUPERVISOR_FRONTEND_URL=https://supervisor.university.com
CENTER_FRONTEND_URL=https://center.university.com

# ── SMTP Email ────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@university.ac.in
SMTP_PASS=your-app-specific-password
SMTP_FROM="Periyar University PhD Admissions <no-reply@university.ac.in>"

# ── Payment Gateway — Paytm ───────────────────────────────────────────────────
PAYTM_MID=YOUR_MERCHANT_ID
PAYTM_KEY=YOUR_MERCHANT_KEY
PAYTM_WEBSITE=DEFAULT
PAYMENT_CALLBACK_URL=https://student.university.com/api/payment/callback
PAYMENT_RETURN_URL=https://student.university.com/payment-status

# ── Backup ────────────────────────────────────────────────────────────────────
# How many days of daily backups to retain
BACKUP_RETENTION_DAYS=30

# ── SSL — managed by scripts/ssl-setup.sh ────────────────────────────────────
# SSL_EMAIL: used by Certbot for Let's Encrypt certificate notifications
SSL_EMAIL=admin@university.ac.in
# Space-separated list of domains to issue certificates for
SSL_DOMAINS=student.university.com admin.university.com supervisor.university.com center.university.com

# ── Monitoring ────────────────────────────────────────────────────────────────
# GRAFANA_ADMIN_PASSWORD: password for Grafana UI (if using monitoring stack)
GRAFANA_ADMIN_PASSWORD=CHANGE_THIS_GRAFANA_PASSWORD

