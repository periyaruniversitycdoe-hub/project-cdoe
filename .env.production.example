# =============================================================================
#  Production environment template — University VPS deployment
#  Copy to .env.production and fill in real values before running:
#    node build_frontend.js --production
# =============================================================================

# ── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=rsm_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=rsm_db

# ── Backend ports (PM2 or systemd services) ───────────────────────────────────
STUDENT_BACKEND_PORT=5000
ADMIN_BACKEND_PORT=5001
SUPERVISOR_BACKEND_PORT=5002
CENTER_BACKEND_PORT=5003

# ── Production domain ─────────────────────────────────────────────────────────
# The public domain of your server (no trailing slash)
# Example: https://phd.periyaruniversity.ac.in
DOMAIN=https://YOUR_DOMAIN

# ── Frontend API base URLs (used by build_frontend.js --production) ───────────
# Pattern: DOMAIN/portal-name  — Nginx strips the prefix before forwarding to backend
VITE_STUDENT_API_URL=${DOMAIN}/student
VITE_ADMIN_API_URL=${DOMAIN}/admin
VITE_SUPERVISOR_API_URL=${DOMAIN}/supervisor
VITE_CENTER_API_URL=${DOMAIN}/center

# ── JWT Secrets (generate with: openssl rand -base64 64) ─────────────────────
STUDENT_JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
ADMIN_JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
SUPERVISOR_JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
CENTER_JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
STUDENT_REFRESH_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
ADMIN_REFRESH_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
SUPERVISOR_REFRESH_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
CENTER_REFRESH_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@domain.ac.in
SMTP_PASS=YOUR_APP_PASSWORD
SMTP_FROM=your-email@domain.ac.in

# ── Frontend URLs (for backend CORS allowlist) ────────────────────────────────
STUDENT_FRONTEND_URL=${DOMAIN}
ADMIN_FRONTEND_URL=${DOMAIN}
SUPERVISOR_FRONTEND_URL=${DOMAIN}
CENTER_FRONTEND_URL=${DOMAIN}

# ── Payment callback (must be publicly reachable) ────────────────────────────
PAYTM_CALLBACK_URL=${DOMAIN}/student/api/payment/callback
PAYMENT_RETURN_URL=${DOMAIN}/student/payment/callback
PAYMENT_WEBHOOK_BASE_URL=${DOMAIN}/student

# ── MFA encryption key (openssl rand -hex 32) ────────────────────────────────
MFA_ENCRYPTION_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL
